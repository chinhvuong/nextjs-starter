  amount: string,
  decimals: number,
  displayDecimals: number = 4
): string => {
  // Implementation
};
```

## Testing Mindset

Write code that's easy to test:

```typescript
// ✅ GOOD - Pure function, easy to test
export const calculateInterest = (
  principal: number,
  rate: number,
  time: number
): number => {
  return principal * rate * time;
};

// ✅ GOOD - Separated concerns
export const useBorrowForm = () => {
  // Logic only
};

export const BorrowForm = () => {
  const logic = useBorrowForm();
  // UI only
  return <form>{/* ... */}</form>;
};

// ❌ BAD - Mixed concerns, hard to test
export const BorrowForm = () => {
  // Both logic and UI tightly coupled
};
```

## Quick Checklist

Before committing code, verify:

- ✅ File is under 500 lines
- ✅ Imports are organized properly
- ✅ TypeScript types are defined
- ✅ Error handling is implemented
- ✅ No console.logs (except in development)
- ✅ No commented-out code
- ✅ Meaningful variable and function names
- ✅ Proper accessibility attributes
- ✅ Responsive design considered
- ✅ Performance optimizations applied where needed
